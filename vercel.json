{
  "version": 2,
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "functions": {
    "index.php": { "runtime": "vercel-php@0.7.1" },
    "cart/product.php": { "runtime": "vercel-php@0.7.1" },
    "cart/cart.php": { "runtime": "vercel-php@0.7.1" },
    "dashboard/dashboard.php": { "runtime": "vercel-php@0.7.1" },
    "api/*.php": { "runtime": "vercel-php@0.7.1" }
  },
  "routes": [
    {
      "src": "/cart/product.php",
      "dest": "/cart/product.php",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" }
    },
    {
      "src": "/cart/cart.php",
      "dest": "/cart/cart.php"
    },
    {
      "src": "/dashboard/dashboard.php",
      "dest": "/dashboard/dashboard.php"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}