{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2",
      "includeFiles": "**/*.php"
    }
  },
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/(?!.*\\.(?:css|js|png|jpg|jpeg|gif|svg|ico|webp)$)(.*)$",
      "dest": "api/index.php"
    }
  ]
}