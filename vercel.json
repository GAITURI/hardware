{
  "version": 2,
  "builds": [
    {
      "src": "**/*.php",
      "use": "vercel-php@0.7.1"
    },
    {
      "src": "**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "**/.*js",
      "use": "@vercel/static"
    },
    {
      "src": "images/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/images/(.*)",
      "dest": "/images/$1"
    },
    {
      "src": "^/dashboard/styles.css$",
      "dest": "/dashboard/styles.css"
    },
    {
      "src": "^/dashboard/app.js$",
      "dest": "/dashboard/app.js"
    },
    {
      "src": "^/dashboard/cart-drawer.js$",
      "dest": "/dashboard/cart-drawer.js"
    },
    {
      "src": "^/cart/cart.css$",
      "dest": "/cart/cart.css"
    },
    {
      "src": "^/cart/product.css$",
      "dest": "/cart/product.css"
    },
    {
      "src": "^/cart/cart.js$",
      "dest": "/cart/cart.js"
    },
    {
      "src": "^/cart/product.js$",
      "dest": "/cart/product.js"
    },
    {
      "src": "^/cart/product.php(.*)",
      "dest": "/cart/product.php$1"
    },
    {
      "src": "^/cart/cart.php(.*)",
      "dest": "/cart/cart.php$1"
    },
    {
      "src": "^/$",
      "dest": "/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}