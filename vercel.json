{
  "version": 2,
  "builds": [
    { "src": "index.php", "use": "vercel-php@0.7.1" },
    { "src": "cart/product.php", "use": "vercel-php@0.7.1" },
    { "src": "cart/cart.php", "use": "vercel-php@0.7.1" },
    { "src": "dashboard/dashboard.php", "use": "vercel-php@0.7.1" },
    { "src": "api/**/*.php", "use": "vercel-php@0.7.1" },
    { "src": "**/*.css", "use": "@vercel/static" },
    { "src": "**/*.js", "use": "@vercel/static" },
    { "src": "**/*.{png,jpg,jpeg,svg,gif,ico}", "use": "@vercel/static" },
    { "src": "**/*.html", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/cart/product.php",
      "dest": "/cart/product.php",
      "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" }
    },
    {
      "src": "/cart/cart.php",
      "dest": "/cart/cart.php"
    },
    {
      "src": "/dashboard/dashboard.php",
      "dest": "/dashboard/dashboard.php"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}