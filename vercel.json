{
    "version": 2,
    "builds": [
      {
        "src": "**/*.php",
        "use": "vercel-php@0.7.1"
      },
      {
        "src": "images/**/*",
        "use": "@vercel/static"
      },
      {
        "src": "css/**/*",
        "use": "@vercel/static"
      },
      {
        "src": "js/**/*",
        "use": "@vercel/static"
      }
    ],
    "routes": [
      {
        "src": "/(images|css|js)/(.*)",
        "dest": "/$1/$2"
      },
      {
        "src": "/(.*)",
        "dest": "/$1"
      }
    ]
  }