{
  "version": 2,
  "builds": [
    {
      "src": "**/*.php",
      "use": "vercel-php@0.7.1"
    },
    {
      "src": "**/!(**/*.php)",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/cart/product.php",
      "dest": "/cart/product.php"
    },
    {
      "src": "/cart/cart.php",
      "dest": "/cart/cart.php"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "^/$",
      "dest": "/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}