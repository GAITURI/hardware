{
    "version": 2,
    "functions": {
      "**/*.php": {
        "runtime": "vercel-php@0.7.1"
      }
    },
    "routes": [
      {
        "src": "/(images|css|js)/(.*)",
        "dest": "/$1/$2"
      },
      {
        "src": "/$",
        "dest": "/dashboard.php"
      },
      {
        "src": "/cart",
        "dest": "/cart/cart.php"
      },
      {
        "src": "/product",
        "dest": "/cart/product.php"
      }
    ]
  }