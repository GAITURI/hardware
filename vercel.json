{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2",
      "includeFiles": "**/*.php"
    }
  },
  "routes": [
    {
      "src": "/(.*\\.php)",
      "dest": "api/index.php"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.php"
    }
  ]
}