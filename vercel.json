{
  "version": 2,
  "builds": [
    { "src": "index.php", "use": "vercel-php@0.7.1" },
    { "src": "cart/product.php", "use": "vercel-php@0.7.1" },
    { "src": "cart/cart.php", "use": "vercel-php@0.7.1" },
    { "src": "dashboard/dashboard.php", "use": "vercel-php@0.7.1" },
    { "src": "api/cart_add.php", "use": "vercel-php@0.7.1" },
    { "src": "api/cart_get.php", "use": "vercel-php@0.7.1" },
    { "src": "api/cart_remove.php", "use": "vercel-php@0.7.1" },
    { "src": "api/cart_update.php", "use": "vercel-php@0.7.1" },
    { "src": "api/fetch.php", "use": "vercel-php@0.7.1" },
    { "src": "api/get_products.php", "use": "vercel-php@0.7.1" },
    { "src": "cart/*.{css,js}", "use": "@vercel/static" },
    { "src": "dashboard/*.{css,js}", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "^/$", "dest": "/index.php" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}