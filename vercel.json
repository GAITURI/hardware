{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.2",
      "includeFiles": "**/*.php"
    }
  },
  "routes": [
    {
      "src": "/(cart|dashboard|images)/(.*\\.(js|css|jpg|jpeg|png|gif|ico|svg|webp))$",
      "dest": "/$1/$2"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*\\.php)",
      "dest": "api/index.php"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.php"
    }
  ]
}